		"@vitest/browser-playwright": "^4.1.10",
		"ansi-colors": "^4.1.3",
		"esbuild": "^0.28.1",
		"playwright": "^1.61.1",
		"react-dom": "^18.3.1",
		"tsx": "^4.23.1",
		"typescript": "^5.4.5",
		"vitest": "^4.1.10",
		"vitest-browser-react": "^2.2.0"
	},
	"peerDependencies": {
		"react": "^18.3.1"
	},
	"dependencies": {
